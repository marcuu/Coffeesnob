# Supabase
#
# Local dev: after `npm run db:start`, copy the API URL and anon key printed
# by the Supabase CLI. The URL is typically http://127.0.0.1:54321; the anon
# key is the long JWT labelled "anon key" in the CLI output.
#
# Production: values from your Supabase project (Settings → API).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — required by the scoring pipeline (API route + CLI
# scripts) to write reviewer_axis_weights / review_weights / venue_axis_scores
# and to drain scoring_dirty_queue. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Bearer token checked by POST /api/scoring/run. Pick any long random string;
# the cron job must send `Authorization: Bearer $SCORING_CRON_SECRET`.
SCORING_CRON_SECRET=

# Set to "true" to read venue scores from venue_axis_scores (weighted pipeline)
# instead of computing simple averages from reviews. Off by default; enable
# after running scoring:backfill and verifying output.
SCORING_USE_WEIGHTED=false
